{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tetorica-deskel",
  "version": "0.6.4",
  "identifier": "net.tetorica.deskel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tetorica Deskel",
        "width": 800,
        "height": 600,
        "transparent": true,
        "decorations": true,
        "alwaysOnTop": false,
        "resizable": true,
        "visible": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
